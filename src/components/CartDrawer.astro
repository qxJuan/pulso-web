<div class="cart-panel" data-cart-drawer aria-hidden="true">
  <div class="cart-panel-backdrop" data-cart-close></div>

  <div class="cart-panel-card">
    <div class="flex items-center justify-between mb-1">
      <span class="font-mono text-eyebrow uppercase tracking-[0.14em] text-crema/50">Tu carrito</span>
      <div class="flex items-center gap-3">
        <span data-cart-panel-count class="font-mono text-xs uppercase tracking-[0.14em] text-crema/70 border border-hairline-inv rounded-full px-3 py-1">
          0 items
        </span>
        <button type="button" data-cart-close aria-label="Cerrar carrito" class="text-crema/50 hover:text-crema transition-colors">
          ✕
        </button>
      </div>
    </div>

    <h3 class="font-display font-medium text-2xl text-crema mb-6">Selección PULSO</h3>

    <div data-cart-items class="max-h-[42vh] overflow-y-auto"></div>

    <div data-cart-empty class="border border-hairline-inv rounded-xl p-6 text-center">
      <span class="font-mono text-eyebrow uppercase tracking-[0.14em] text-crema/40 block mb-3">Vacío por ahora</span>
      <p class="font-display font-medium text-lg text-crema mb-2">Tu carrito está esperando una selección.</p>
      <p class="text-crema/60 text-sm leading-relaxed">
        Abre un producto, elige sus opciones y añádelo para armar tu pedido.
      </p>
    </div>

    <div class="mt-6 pt-5 border-t border-hairline-inv">
      <div class="flex items-center justify-between mb-1">
        <span class="font-mono text-xs uppercase tracking-[0.14em] text-crema/50">Total en carrito</span>
        <button type="button" data-cart-clear class="font-mono text-xs uppercase tracking-[0.14em] text-crema/50 hover:text-crema transition-colors">
          Vaciar
        </button>
      </div>
      <p data-cart-total-label class="font-display font-medium text-lg text-crema mb-5">0 productos</p>
      <button
        type="button"
        data-cart-checkout
        disabled
        class="w-full inline-flex items-center justify-center gap-2 bg-crema text-carbono px-6 py-3.5 font-body font-medium text-sm tracking-wide transition-all duration-300 hover:bg-white opacity-40 pointer-events-none"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
          <path d="M12 2a10 10 0 0 0-8.6 15.1L2 22l5.05-1.36A10 10 0 1 0 12 2Zm0 18.2a8.16 8.16 0 0 1-4.17-1.14l-.3-.18-3.1.84.84-3.02-.2-.3A8.2 8.2 0 1 1 12 20.2Zm4.5-6.13c-.24-.12-1.44-.71-1.66-.8-.22-.08-.39-.12-.55.12-.16.24-.63.8-.78.97-.14.16-.29.18-.53.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.44-1.34-1.68-.14-.24-.02-.37.1-.49.11-.11.24-.28.36-.42.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.32-.75-1.8-.2-.48-.4-.42-.55-.42h-.47c-.16 0-.42.06-.64.3-.22.24-.85.83-.85 2.02 0 1.19.87 2.34 1 2.5.12.16 1.71 2.6 4.15 3.65.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.44-.59 1.64-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28Z"/>
        </svg>
        Solicitar pedido
      </button>
    </div>
  </div>
</div>
